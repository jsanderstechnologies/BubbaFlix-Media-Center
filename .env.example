# ============================================================
# BubbaFlix Media Center — Environment Variable Reference
# ============================================================
# Copy this file to docker-compose.yml and fill in your values.
# NEVER commit real secrets to version control.
# ============================================================

# Required: TMDB API key for movie/TV metadata
# Get yours at https://www.themoviedb.org/settings/api
TMDB_KEY=""

# Required: TorBox API key for Usenet downloading & streaming
# Get yours at https://torbox.app/settings
TORBOX_API_KEY=""
